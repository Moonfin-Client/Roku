import "pkg:/source/utils/misc.bs"
import "pkg:/source/utils/themeRegistry.bs"

sub init()
    m.top.functionName = "loadThemes"
end sub

sub loadThemes()
    m.top.errorMessage = ""
    themes = themeRegistry.GetAvailableThemes()
    if not isValidAndNotEmpty(themes)
        m.top.errorMessage = "No themes available"
        return
    end if
    m.top.themes = themes
end sub
