import "pkg:/source/utils/misc.bs"
import "pkg:/source/utils/themeRegistry.bs"

sub init()
    m.top.functionName = "resolveTheme"
end sub

sub resolveTheme()
    m.top.errorMessage = ""
    theme = themeRegistry.GetThemeById(m.top.themeId)
    if not isValid(theme)
        m.top.errorMessage = "Theme could not be loaded"
        return
    end if
    m.top.theme = theme
end sub
