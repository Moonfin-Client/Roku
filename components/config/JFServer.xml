<?xml version="1.0" encoding="utf-8"?>
<component name="JFServer" extends="Group">

  <interface>
    <field id="itemContent" type="node" onchange="itemContentChanged" />
    <field id="itemHasFocus" type="boolean" onchange="onItemHasFocusChange" />
  </interface>

  <children>
    <Rectangle id="background" translation="[0,0]" width="1540" height="60" />

    <Poster id="poster" translation="[10,10]" width="40" height="40" />
    <Group id="labels" translation="[120,15]">
      <Text id="serverInfo" horizAlign="center" font="font:SmallerSystemFont" height="65" width="1320" />
    </Group>

    <Rectangle id="trashContainer" translation="[1480,0]" width="60" height="60">
      <Poster id="trash" width="25" height="25" uri="pkg:/images/icons/trash.png" translation="[18,18]" />
    </Rectangle>
  </children>

</component>