<?xml version="1.0" encoding="utf-8"?>
<component name="ShuffleDialog" extends="Group" initialFocus="posterGroup0">
    <children>
        <Rectangle id="shuffleBackdrop" width="1920" height="1080" color="0x000000" opacity="0.7" />
        <Rectangle id="shuffleBackground" width="1500" height="900" color="#101010" translation="[210, 90]" />

        <Group id="dialogPanel" translation="[960, 160]">
            <Label id="loadingLabel" text="Loading shuffle items..." font="font:MediumBoldSystemFont" color="#CCCCCC" horizAlign="left" translation="[-200, 340]" visible="false" />

            <LayoutGroup id="posterRow" layoutDirection="horiz" horizAlignment="center" itemSpacings="[24]" translation="[0, 0]">
                <Group id="posterGroup0" focusable="true">
                    <Poster id="posterImg0" width="245" height="367" loadDisplayMode="scaleToZoom" />
                    <Poster id="posterFocus0" width="245" height="367" uri="pkg:/images/posterFocus.9.png" visible="false" />
                </Group>
                <Group id="posterGroup1" focusable="true">
                    <Poster id="posterImg1" width="245" height="367" loadDisplayMode="scaleToZoom" />
                    <Poster id="posterFocus1" width="245" height="367" uri="pkg:/images/posterFocus.9.png" visible="false" />
                </Group>
                <Group id="posterGroup2" focusable="true">
                    <Poster id="posterImg2" width="245" height="367" loadDisplayMode="scaleToZoom" />
                    <Poster id="posterFocus2" width="245" height="367" uri="pkg:/images/posterFocus.9.png" visible="false" />
                </Group>
                <Group id="posterGroup3" focusable="true">
                    <Poster id="posterImg3" width="245" height="367" loadDisplayMode="scaleToZoom" />
                    <Poster id="posterFocus3" width="245" height="367" uri="pkg:/images/posterFocus.9.png" visible="false" />
                </Group>
                <Group id="posterGroup4" focusable="true">
                    <Poster id="posterImg4" width="245" height="367" loadDisplayMode="scaleToZoom" />
                    <Poster id="posterFocus4" width="245" height="367" uri="pkg:/images/posterFocus.9.png" visible="false" />
                </Group>
            </LayoutGroup>

            <Group id="infoOverview" translation="[-650, 440]">
                <Label id="itemTitle" font="font:MediumBoldSystemFont" color="0xFFFFFFFF" horizAlign="left" wrap="true" width="700" translation="[0, 0]" />
                <LayoutGroup id="metadataRow" layoutDirection="horiz" horizAlignment="left" itemSpacings="[12]" translation="[0, 40]" visible="false">
                    <Label id="yearLabel" font="font:SmallestBoldSystemFont" color="0xFFFFFFFF" />
                    <Label id="runtimeLabel" font="font:SmallestBoldSystemFont" color="0xFFFFFFFF" />
                    <Label id="itemRating" font="font:SmallestBoldSystemFont" color="0xFFFFFFFF" />
                </LayoutGroup>
                <Label id="overviewLabel" font="font:SmallestSystemFont" color="0xFFFFFFFF" horizAlign="left" wrap="true" width="1322" maxLines="4" lineSpacing="4" translation="[0, 80]" />
            </Group>

            <LayoutGroup id="buttonRow" layoutDirection="horiz" horizAlignment="center" itemSpacings="[24]" translation="[0, 700]">
                <StandardButton id="libraryShuffleBtn" text="Library Shuffle" width="384" height="80" fontSize="22" />
                <StandardButton id="randomShuffleBtn" text="Random Shuffle" width="513" height="80" fontSize="22" />
                <StandardButton id="genresShuffleBtn" text="Genres Shuffle" width="384" height="80" fontSize="22" />
            </LayoutGroup>
        </Group>
    </children>
    <interface>
        <field id="contentType" type="string" />
        <field id="selectedItem" type="node" alwaysNotify="true" />
        <field id="shuffleDialogClosed" type="boolean" alwaysNotify="true" />
    </interface>
</component>